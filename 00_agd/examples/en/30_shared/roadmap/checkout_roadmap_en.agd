	1)
	2)

	[Platform]
	1)
	2)

	[Operations]
	1)
	2)
	>>>
}

@section RD-030
title: Metrics
{
	summary: Track outcome and quality in one view
	links: KPI-BOARD-001
	content:
	<<<
	[Core KPIs]
	1)
	2)
	3)

	[Risk indicators]
	1)
	2)
	>>>
}

@section RD-040
title: Risk Mitigation
{
	summary: Define mitigation owner and plan before risk materializes
	links: RISK-REGISTER-001
	content:
	<<<
	1) Risk:
	   - Mitigation:
	2) Risk:
	   - Mitigation:
	3) Risk:
	   - Mitigation:
	>>>
}

